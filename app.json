{
  "expo": {
    "name": "Schraderbräu",
    "slug": "my-app-cerveja",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconGR.png",
    "scheme": "myappcerveja",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/iconGR.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Este aplicativo precisa de acesso contínuo ao Bluetooth para monitorar e controlar o tanque de cerveja."
      },
      "bundleIdentifier": "com.devtsurus.cerveja"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.devtsurus.cerveja",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/iconGR.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-splash-screen",
      "expo-status-bar",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Permitir que o aplicativo se conecte ao ESP32 do tanque de cerveja."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d6eadb27-5aa7-40c9-a6e2-5e15f4712065"
      }
    }
  }
}
